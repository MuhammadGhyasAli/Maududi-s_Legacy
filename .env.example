# ═══════════════════════════════════════════
# Maududi's Legacy — Environment Variables
# ═══════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# NEVER commit the actual .env file (it is gitignored).
#
# Required vars are marked [REQUIRED]
# Optional vars have sensible defaults shown.

# ─── Core ──────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ─── MongoDB ───────────────────────────────
# [REQUIRED] Connection string for MongoDB (Atlas or local)
MONGODB_URL=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=maududi_legacy

# ─── AI / Groq ─────────────────────────────
# [REQUIRED] Groq API key for AI chat features
# Get one at: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq model overrides (optional)
# GROQ_MODEL_TEXT=llama-3.3-70b-versatile
# GROQ_MODEL_VISION=llama-3.2-11b-vision-preview

# ─── Auth / JWT ────────────────────────────
# [REQUIRED] Generate a secure random key:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET_KEY=<generate-a-random-64-char-hex-string>
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# Password reset (optional)
PASSWORD_RESET_TTL_MINUTES=30
DEV_RETURN_PASSWORD_RESET_TOKEN=false

# ─── Google OAuth ──────────────────────────
# [OPTIONAL] For "Sign in with Google" button
# Create credentials at: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ─── Email (Password Reset) ────────────────
# [OPTIONAL] SMTP credentials for sending password reset emails
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=noreply@maududilegacy.com

# ─── Cache ─────────────────────────────────
CACHE_TTL_SECONDS=300
CACHE_MAXSIZE=1000

# ─── Rate Limiting ─────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60
