## Core
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

## Database
# Development (SQLite):
DATABASE_URL=sqlite:///./maududi_legacy.db
# Production (PostgreSQL example):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/maududi_legacy

## AI providers
GOOGLE_API_KEY=your_google_api_key_here

## Auth / JWT
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

## Password reset
PASSWORD_RESET_TTL_MINUTES=30
# For development only (do not enable in production)
DEV_RETURN_PASSWORD_RESET_TOKEN=true
